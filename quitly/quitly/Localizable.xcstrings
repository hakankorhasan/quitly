    },
    "mq_quote_187" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا تحتاج إلى الرد. فقط لاحظ."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie müssen nicht reagieren. Beobachte einfach."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The calm after the storm is called sobriety."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"No necesitas reaccionar. Solo observa.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
