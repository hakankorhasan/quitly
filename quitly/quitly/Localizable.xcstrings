        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "갈망은 지나갈 것입니다. 당신의 힘은 그렇지 않습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A vontade vai passar. Sua força não."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тяга пройдет. Твоя сила не поможет."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arzu geçecek. Gücün geçmeyecek."
