            "value" : "少し時間をください。この気持ちは薄れていきます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "약간의 시간을 주십시오. 이 느낌은 사라질 것입니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dê um pouco de tempo. Esse sentimento irá desaparecer."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дайте этому немного времени. Это чувство исчезнет."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Biraz zaman ver. Bu his kaybolup gidecek."
