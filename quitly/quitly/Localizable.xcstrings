    },
    "mq_quote_186" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هدئ عقلك وثق بقرارك."
          }
        },
        "de" : {
          "stringUnit" : {
