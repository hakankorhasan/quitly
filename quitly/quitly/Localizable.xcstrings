    "mq_quote_142" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لقد أثبتت بالفعل قوتك. استمر في إثبات ذلك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
