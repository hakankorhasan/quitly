        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Güç böyle anlarda inşa edilir. Onu ziyan etme."
          }
        }
      }
    },
    "mq_quote_124": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are not alone in this fight. Stay strong."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"No estás solo en esta lucha. Mantente fuerte.\","
