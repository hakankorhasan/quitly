    "mq_quote_108": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Discipline is your advantage. Use it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"La disciplina es tu ventaja. Úsala.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Disiplin senin avantajındır. Onu kullan."
          }
        }
      }
    },
    "mq_quote_109": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every time you say no, you get stronger."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Cada vez que dices \\\"no\\\", te vuelves más fuerte.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Hayır\" dediğin her an, daha da güçlenirsin."
          }
        }
      }
    },
    "mq_quote_110": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Think about why you started. That reason still matters."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Piensa en por qué empezaste. Esa razón aún importa.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Neden başladığını düşün. O sebep hâlâ geçerli."
          }
        }
      }
    },
    "mq_quote_111": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You don’t need to react to every thought. Let this one pass."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"No necesitas reaccionar a cada pensamiento. Deja pasar este.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her düşünceye tepki vermek zorunda değilsin. Bırak bu da geçip gitsin."
          }
        }
      }
    },
    "mq_quote_112": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your mind is trying to trick you. Don’t fall for it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Tu mente está intentando engañarte. No caigas en la trampa.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Zihnin seni kandırmaya çalışıyor. Bu tuzağa düşme."
          }
        }
      }
    },
    "mq_quote_113": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You already know the outcome. Choose better this time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Ya conoces el resultado. Elige mejor esta vez.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sonucun ne olacağını zaten biliyorsun. Bu kez daha iyisini seç."
          }
        }
      }
    },
    "mq_quote_114": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This isn’t worth breaking your progress."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"No vale la pena arruinar tu progreso por esto.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu, ilerlemeni bozmaya değmez."
          }
        }
      }
    },
    "mq_quote_115": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Be aware of the moment instead of controlled by it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Sé consciente del momento en lugar de ser controlado por él.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Anın seni kontrol etmesine izin vermek yerine anın farkında ol."
          }
        }
      }
    },
    "mq_quote_116": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your thoughts don’t control you. Your actions do."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Tus pensamientos no te controlan. Tus acciones sí.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Düşüncelerin seni kontrol etmez. Eylemlerin eder."
          }
        }
      }
    },
    "mq_quote_117": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is just noise. Stay focused on your goal."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Esto es solo ruido. Mantente enfocado en tu objetivo.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu sadece bir gürültü. Hedefine odaklı kal."
          }
        }
      }
    },
    "mq_quote_118": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay conscious. Don’t act on impulse."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Mantente consciente. No actúes por impulso.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bilincini açık tut. Dürtüyle hareket etme."
          }
        }
      }
    },
    "mq_quote_119": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Make a decision your future self will respect."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Toma una decisión que tu yo del futuro respetará.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gelecekteki senin saygı duyacağı bir karar ver."
          }
        }
      }
    },
    "mq_quote_120": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are stronger than your weakest moment."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Eres más fuerte que tu momento más débil.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sen en zayıf anından daha güçlüsün."
          }
        }
      }
    },
    "mq_quote_121": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This feeling is temporary, but your strength is permanent."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Este sentimiento es temporal, pero tu fuerza es permanente.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu his geçici, ancak gücün kalıcı."
          }
