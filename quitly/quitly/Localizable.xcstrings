    },
    "mq_quote_17" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الرغبة عالية، لكن انضباطك يجب أن يكون أعلى."
