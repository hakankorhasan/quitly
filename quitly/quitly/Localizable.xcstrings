          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 순간은 일시적입니다. 당신의 진전은 그렇지 않습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
