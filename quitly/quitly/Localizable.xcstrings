    "mq_quote_158" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كن صبورا. أنت تقوم بعمل أفضل مما تعتقد."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bleiben Sie geduldig. Dir geht es besser, als du denkst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alcohol was a symptom. Sobriety is the cure."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Sé paciente. Lo estás haciendo mejor de lo que crees.\","
