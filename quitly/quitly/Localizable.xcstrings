    "mq_quote_128": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You’re doing something most people can’t. Be proud."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Estás haciendo algo que la mayoría no puede. Siéntete orgulloso.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Çoğu insanın yapamadığı bir şeyi yapıyorsun. Gurur duy."
          }
