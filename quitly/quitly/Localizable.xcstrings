        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "숨 쉬다. 당신은 정말 놀라운 일을 하고 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
