        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这一刻是暂时的。你的进步不是。"
          }
        }
      }
    },
    "mq_quote_155" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ابق قويا لفترة أطول قليلا. أنت على وشك الوصول."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bleib noch ein bisschen länger stark. Du bist fast da."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You found what alcohol could never give you: real peace."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Mantente fuerte un poco más. Ya casi estás ahí.\","
