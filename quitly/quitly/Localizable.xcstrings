      }
    },
    "mq_quote_193": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Don’t give up. Not this time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"No te rindas. Esta vez no.\","
          }
