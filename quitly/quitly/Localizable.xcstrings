    "mq_quote_39" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا تدع لحظة ضعيفة تحدد هويتك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lass dich nicht von einem schwachen Moment definieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recovery is an acceptance that your life is in shambles and you have to change it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"No dejes que un momento de debilidad te defina.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ne laissez pas un moment de faiblesse vous définir."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "弱い瞬間が自分を定義づけないでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "약한 순간이 당신을 정의하도록 두지 마십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Não deixe um momento de fraqueza definir você."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не позволяй моменту слабости определять тебя."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zayıf bir anın seni tanımlamasına izin verme."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不要让软弱的时刻定义你。"
          }
        }
      }
    },
    "mq_quote_40" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "خذ نفسا عميقا. لا تحتاج إلى الرد على الفور."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atmen Sie tief ein. Sie müssen nicht sofort reagieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Be proud of how hard you are trying."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Respira profundo. No necesitas reaccionar de inmediato.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Respirez profondément. Vous n’avez pas besoin de réagir immédiatement."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "深呼吸してください。すぐに反応する必要はありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "심호흡을 해보세요. 즉시 대응할 필요는 없습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Respire fundo. Você não precisa reagir imediatamente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сделайте глубокий вдох. Не обязательно реагировать немедленно."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Derin bir nefes al. Hemen tepki vermek zorunda değilsin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "深吸一口气。你不需要立即做出反应。"
          }
        }
      }
    },
    "mq_quote_41" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ابطئ. سوف يمر هذا الشعور إذا أعطيته الوقت."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verlangsamen. Dieses Gefühl wird vergehen, wenn Sie ihm Zeit geben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "It does not matter how slowly you go, as long as you do not stop."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Ve más despacio. Este sentimiento pasará si le das tiempo.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ralentir. Ce sentiment passera si vous lui donnez le temps."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "減速する。この気持ちは時間が経てば消えます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "천천히 하세요. 이 감정은 시간을 들이면 지나갈 것입니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desacelerar. Esse sentimento vai passar se você der um tempo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Замедлять. Это чувство пройдет, если вы дадите ему время."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yavaşla. Zaman verirsen bu his geçecek."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "减速。如果你给它时间，这种感觉就会过去。"
          }
        }
      }
    },
    "mq_quote_42" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنت آمن. أنت بخير. مجرد التنفس والبقاء حاضرا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du bist in Sicherheit. Dir geht es gut. Atme einfach und bleibe präsent."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your health is an investment, not an expense."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Estás a salvo. Estás bien. Solo respira y mantente presente.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous êtes en sécurité. Tu vas bien. Respirez simplement et restez présent."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたは安全です。大丈夫ですよ。ただ呼吸して、そこに留まってください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신은 안전합니다. 당신은 괜찮습니다. 숨을 쉬고 현재 상태를 유지하십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você está seguro. Você está bem. Apenas respire e fique presente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы в безопасности. С тобой все в порядке. Просто дышите и оставайтесь присутствующим."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Güvendesin. İyisin. Sadece nefes al ve anda kal."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你很安全。你没事吧。只需呼吸并保持在场即可。"
          }
        }
      }
    },
    "mq_quote_43" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ليس كل فكرة تستحق رد فعل. دعها تذهب."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nicht jeder Gedanke verdient eine Reaktion. Lassen Sie es gehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The first step towards getting somewhere is to decide you're not going to stay where you are."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"No todo pensamiento merece una reacción. Déjalo ir.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toutes les pensées ne méritent pas une réaction. Laisse tomber."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべての考えが反応に値するわけではありません。放っておいて。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모든 생각이 반응을 받을 만한 가치가 있는 것은 아닙니다. 놔두세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nem todo pensamento merece uma reação. Deixa para lá."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не каждая мысль заслуживает реакции. Отпусти ситуацию."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Her düşünce bir tepkiyi hak etmez. Bırak gitsin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "并非每个想法都值得回应。放手吧。"
          }
        }
      }
    },
    "mq_quote_44" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حافظ على هدوئك ولاحظ هذا الشعور دون التصرف بناءً عليه."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bleiben Sie ruhig und beobachten Sie das Gefühl, ohne darauf zu reagieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sober isn't boring. Hangovers are boring."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Mantén la calma y observa el sentimiento sin actuar.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restez calme et observez la sensation sans agir en conséquence."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "感情に基づいて行動することなく、落ち着いて感情を観察してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "행동을 취하지 말고 침착함을 유지하고 그 느낌을 관찰하십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fique calmo e observe o sentimento sem agir de acordo com ele."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сохраняйте спокойствие и наблюдайте за чувством, не реагируя на него."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sakin ol ve harekete geçmeden o hissi gözlemle."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保持冷静，观察这种感觉，但不要采取行动。"
          }
        }
      }
    },
    "mq_quote_45" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنت لست أفكارك. أنت الذي تسيطر عليهم."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du bist nicht deine Gedanken. Du bist derjenige, der sie kontrolliert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I'm not telling you it's going to be easy — I'm telling you it's going to be worth it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"No eres tus pensamientos. Eres quien los controla.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous n'êtes pas vos pensées. C'est vous qui les contrôlez."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたはあなたの考えではありません。それらをコントロールするのはあなたです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신은 당신의 생각이 아닙니다. 당신은 그들을 통제하는 사람입니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você não é seus pensamentos. Você é quem os controla."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы не являетесь своими мыслями. Вы тот, кто управляет ими."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sen düşüncelerin değilsin. Sen onları kontrol edensin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你不是你的想法。你是控制他们的人。"
          }
        }
      }
    },
    "mq_quote_46" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تنفس بقوة، وزفير الرغبة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atme Kraft ein, atme den Drang aus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Today is a perfect day to start living the way you've always wanted."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Inhala fuerza, exhala el impulso.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Respirez avec force, expirez avec envie."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "力を吸い込み、衝動を吐き出します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "힘을 들이마시고 충동을 내쉬십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inspire com força, expire com vontade."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вдохните силу, выдохните желание."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gücü içine çek, dürtüyü dışarı üfle."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "吸入力量，呼出冲动。"
          }
        }
      }
    },
    "mq_quote_47" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ابقَ على الأرض. هذه اللحظة لا تسيطر عليك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bleiben Sie auf dem Boden. Dieser Moment kontrolliert dich nicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You are the author of your own story. Make it a good one."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Mantén los pies en la tierra. Este momento no te controla.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restez ancré. Ce moment ne vous contrôle pas."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "地に足をつけてください。この瞬間はあなたをコントロールするものではありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "접지 상태를 유지하세요. 이 순간은 당신을 통제하지 않습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fique com os pés no chão. Este momento não controla você."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Оставайтесь заземленными. Этот момент не контролирует вас."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ayakların yere sağlam bassın. Bu an seni kontrol edemez."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保持脚踏实地。这一刻无法控制你。"
          }
        }
      }
    },
    "mq_quote_48" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هدئ عقلك وثق بقرارك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beruhige deinen Geist und vertraue deiner Entscheidung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Courage doesn't always roar. Sometimes it's the quiet voice at the end of the day saying, 'I will try again tomorrow.'"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Calma tu mente y confía en tu decisión.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Calmez votre esprit et faites confiance à votre décision."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "心を落ち着かせて、自分の決断を信じてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "마음을 진정시키고 당신의 결정을 믿으세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acalme sua mente e confie em sua decisão."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Успокойте свой разум и доверьтесь своему решению."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zihnini sakinleştir ve kararına güven."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "冷静下来并相信自己的决定。"
          }
        }
      }
    },
    "mq_quote_49" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "السلام يأتي من السيطرة، وليس من الاستسلام."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frieden entsteht durch Kontrolle, nicht durch Nachgeben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your sobriety is the foundation for every dream you've ever had."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"La paz viene del control, no de rendirse.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La paix vient du contrôle et non de la soumission."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "平和は、屈服することによってではなく、コントロールによってもたらされます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "평화는 굴복이 아니라 통제에서 나옵니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A paz vem do controle, não da cedência."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Мир приходит от контроля, а не от уступок."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Huzur pes etmekten değil, kontrolü elinde tutmaktan gelir."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "和平来自控制，而不是屈服。"
          }
        }
      }
    },
    "mq_quote_50" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "البدء من جديد أصعب من الاستمرار. لا تقم بإعادة التعيين الآن."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Von vorne anzufangen ist schwieriger als weiterzumachen. Jetzt nicht zurücksetzen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Every day sober is a day you chose yourself."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Empezar de nuevo es más difícil que continuar. No reinicies ahora.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il est plus difficile de recommencer que de continuer. Ne réinitialisez pas maintenant."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "やり直すことは続けることよりも難しいことです。今はリセットしないでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "다시 시작하는 것이 계속하는 것보다 어렵습니다. 지금은 재설정하지 마세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recomeçar é mais difícil do que continuar. Não reinicie agora."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Начать заново труднее, чем продолжать. Don’t reset now."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Baştan başlamak, devam etmekten daha zordur. Şimdi sıfırlama."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "重新开始比继续更难。现在不要重置。"
          }
        }
      }
    },
    "mq_quote_51" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنت تعرف بالفعل إلى أين تؤدي العودة. اختر للأمام."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie wissen bereits, wohin die Rückkehr führt. Wählen Sie vorwärts."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The chains of addiction are too light to be felt until they are too heavy to be carried."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Ya sabes a dónde lleva mirar atrás. Elige ir hacia adelante.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous savez déjà où mène le retour en arrière. Choisissez en avant."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "戻ることがどこにつながるかはすでにわかっています。前進を選択してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신은 이미 돌아갈 곳이 어디로 가는지 알고 있습니다. 앞으로 선택하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você já sabe aonde leva voltar. Escolha avançar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы уже знаете, к чему приведет возвращение назад. Выбирайте вперед."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geriye dönmenin nereye vardığını zaten biliyorsun. İleri gitmeyi seç."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你已经知道回去会通向何方。选择前进。"
          }
        }
      }
    },
    "mq_quote_52" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "خطأ واحد يمكن أن يبطل أيامًا من الجهد. حافظ على تركيزك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein Fehler kann tagelange Bemühungen zunichte machen. Bleiben Sie konzentriert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sobriety delivered everything alcohol promised."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Un error puede deshacer días de esfuerzo. Mantente enfocado.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une erreur peut annuler des jours d’efforts. Restez concentré."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一つの間違いが何日にもわたる努力を水の泡にしてしまう可能性があります。集中力を維持しましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "한 번의 실수로 며칠 간의 노력이 물거품이 될 수 있습니다. 집중하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um erro pode desfazer dias de esforço. Mantenha o foco."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Одна ошибка может свести на нет многодневные усилия. Оставайтесь сосредоточенными."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bir hata günlerce süren çabayı yok edebilir. Odaklan."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一个错误可能会毁掉几天的努力。保持专注。"
          }
        }
      }
    },
    "mq_quote_53" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا تخلف وعدك لنفسك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brechen Sie nicht Ihr Versprechen an sich selbst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're not starting over — you're starting with experience."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"No rompas la promesa que te hiciste.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ne rompez pas votre promesse envers vous-même."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自分自身との約束を破らないでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "자신과의 약속을 어기지 마세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Não quebre sua promessa a si mesmo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не нарушайте данное себе обещание."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kendine verdiğin sözü bozma."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不要违背对自己的承诺。"
          }
        }
      }
    },
    "mq_quote_54" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لقد عملت بجد لرميها بعيدًا الآن."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du hast zu hart gearbeitet, um es jetzt wegzuwerfen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The only impossible journey is the one you never begin."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Has trabajado demasiado duro para tirarlo todo por la borda ahora.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous avez travaillé trop dur pour le jeter maintenant."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたは今それを捨てるにはあまりにも一生懸命働きました。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "지금 버리기엔 너무 애썼다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você trabalhou muito para jogá-lo fora agora."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы слишком много работали, чтобы выбросить его сейчас."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Şimdi çöpe atmak için çok fazla çalıştın."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你工作太辛苦了，现在不能把它扔掉。"
          }
        }
      }
    },
    "mq_quote_55" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنت لا تفتقد أي شيء بقول لا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Sie Nein sagen, verpassen Sie nichts."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When you feel like quitting, remember why you started."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"No te estás perdiendo de nada al decir \\\"no\\\".\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous ne manquez rien en disant non."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「ノー」と言っても、何も逃すわけではありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "아니오라고 말하면 아무것도 놓치지 않습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você não está perdendo nada ao dizer não."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы ничего не потеряете, сказав «нет»."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Hayır\" diyerek hiçbir şey kaçırmıyorsun."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "说“不”并不会错过任何东西。"
          }
        }
      }
    },
    "mq_quote_56" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذا مجرد اختبار. تمريرها والمضي قدما."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
