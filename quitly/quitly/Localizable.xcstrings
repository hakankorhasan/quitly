    "mq_quote_178" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا تبطئ الآن. أنت تقوم بعمل رائع."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Machen Sie jetzt nicht langsamer. Du machst das großartig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Every moment of craving you resist is muscle you build."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"No bajes el ritmo ahora. Lo estás haciendo genial.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ne ralentissez pas maintenant. Vous allez très bien."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今は速度を落とさないでください。とても頑張っていますね。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이제 속도를 늦추지 마세요. 당신은 잘하고 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Não diminua a velocidade agora. Você está indo muito bem."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не тормози сейчас. У тебя все отлично."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Şimdi yavaşlama. Harika gidiyorsun."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "现在不要放慢速度。你做得很好。"
          }
        }
      }
    },
    "mq_quote_179" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "استمر في تكديس الانتصارات، يومًا بعد يوم."
