    "mq_quote_57" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لقد وصلت إلى هذا الحد. لا تخريب نفسك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du hast es bis hierher geschafft. Sabotieren Sie sich nicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In the middle of every difficulty lies opportunity."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Has llegado muy lejos. No te sabotees.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous êtes arrivé jusqu’ici. Ne vous sabotez pas."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ここまでやってこれました。自分自身を妨害しないでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여기까지 해냈습니다. 자신을 방해하지 마십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você chegou até aqui. Não se sabote."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы зашли так далеко. Не саботируйте себя."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buraya kadar geldin. Kendi kendini sabote etme."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你已经做到了这一步。不要破坏自己。"
          }
        }
      }
    },
    "mq_quote_58" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الجزء الأصعب هو الآن. تجاوز ذلك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der schwierigste Teil ist jetzt. Komm durch."
          }
