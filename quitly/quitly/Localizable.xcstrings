    },
    "mq_quote_131": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Break the cycle now, not tomorrow."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Rompe el ciclo ahora, no mañana.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Döngüyü yarın değil, şimdi kır."
          }
