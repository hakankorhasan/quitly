    "mq_quote_0" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لقد قطعت شوطا طويلا للانسحاب الآن. لا تدع لحظة واحدة تدمر تقدمك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du bist zu weit gekommen, um jetzt aufzuhören. Lassen Sie nicht zu, dass ein Moment Ihren Fortschritt zerstört."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Every sober day is a gift you give yourself."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Has llegado demasiado lejos para rendirte ahora. No dejes que un momento destruya tu progreso.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous êtes allé trop loin pour arrêter maintenant. Ne laissez pas un instant détruire vos progrès."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "もう辞めるには行き過ぎています。あなたの進歩を一瞬たりとも台無しにしないでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이제 그만 두기엔 너무 멀리 왔어요. 한 순간도 귀하의 진행 상황을 파괴하지 마십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você chegou longe demais para desistir agora. Não deixe que um momento destrua seu progresso."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы зашли слишком далеко, чтобы уйти сейчас. Не позволяйте ни одному моменту разрушить ваш прогресс."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Şimdi bırakmak için çok fazla yol kat ettin. Bir anlık zayıflığın ilerlemeni mahvetmesine izin verme."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你已经走得太远了，现在不能放弃了。不要让任何一刻毁掉你的进步。"
          }
        }
      }
    },
    "mq_quote_1" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "في كل يوم تبقى فيه قويًا، فإنك تبني نسخة أفضل من نفسك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeden Tag, an dem Sie stark bleiben, entwickeln Sie eine bessere Version Ihrer selbst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sobriety is not a sacrifice — it's a superpower."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Cada día que te mantienes fuerte, estás construyendo una mejor versión de ti mismo.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaque jour où vous restez fort, vous construisez une meilleure version de vous-même."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "毎日強くなり続けることで、より良い自分自身を構築することができます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "매일 당신은 강인함을 유지하면서 더 나은 자신의 모습을 만들어가고 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A cada dia que você permanece forte, você constrói uma versão melhor de si mesmo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Каждый день, когда вы остаетесь сильными, вы создаете лучшую версию себя."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Güçlü kaldığın her gün, kendinin daha iyi bir versiyonunu inşa ediyorsun."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每一天你保持坚强，你都在打造一个更好的自己。"
          }
        }
      }
    },
    "mq_quote_2" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذا الخط هو دليل على انضباطك. لا تكسرها من أجل شعور مؤقت."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieser Streak ist ein Beweis für Ihre Disziplin. Unterbrechen Sie es nicht für ein vorübergehendes Gefühl."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The strongest people are those who fight battles others know nothing about."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Esta racha es prueba de tu disciplina. No la rompas por un sentimiento temporal.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette séquence est la preuve de votre discipline. Ne le cassez pas pour un sentiment temporaire."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この連続記録はあなたの規律の証です。一時的な感情で壊さないでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 행진은 당신의 규율을 증명합니다. 일시적인 느낌 때문에 깨지 마세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Essa seqüência é a prova de sua disciplina. Não o quebre por um sentimento temporário."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Эта серия является доказательством вашей дисциплины. Не ломайте его ради временного чувства."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu seri senin disiplininin kanıtı. Geçici bir his için onu bozma."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这一连胜证明了你的纪律性。不要为了一时的感觉而破坏它。"
          }
        }
      }
    },
    "mq_quote_3" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنت لم تصل إلى هذا الحد فقط لتبدأ من جديد. يستمر في التقدم."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du bist nicht so weit gekommen, nur um noch einmal von vorne anzufangen. Weitermachen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You don't have to see the whole staircase, just take the first step."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"No llegaste tan lejos solo para empezar de nuevo. Sigue adelante.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous n’êtes pas venu jusqu’ici juste pour recommencer. Continue."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "もう一度やり直すためだけにここまで来たわけではありません。続けて。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "다시 시작하기 위해 여기까지 온 것이 아닙니다. 계속하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você não veio até aqui apenas para começar de novo. Continue."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы зашли так далеко не для того, чтобы начать все сначала. Продолжать идти."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buraya kadar sadece en baştan başlamak için gelmedin. Devam et."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你走到这一步并不是为了重新开始。继续前进。"
          }
        }
      }
    },
    "mq_quote_4" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "التقدم بطيء، لكن خسارته فورية. حماية ما قمت ببنائه."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Fortschritt ist langsam, aber der Verlust erfolgt sofort. Schützen Sie, was Sie aufgebaut haben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recovery is not for people who need it, it's for people who want it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"El progreso es lento, pero perderlo es instantáneo. Protege lo que has construido.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les progrès sont lents, mais les perdre est instantané. Protégez ce que vous avez construit."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "進歩は遅いですが、それを失うのは一瞬です。自分が構築したものを保護します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "진행은 느리지만 잃는 것은 즉각적입니다. 당신이 구축한 것을 보호하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O progresso é lento, mas perdê-lo é instantâneo. Proteja o que você construiu."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Прогресс медленный, но потеря его мгновенная. Защитите то, что вы построили."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "İlerleme yavaştır, ancak onu kaybetmek an meselesidir. İnşa ettiğin şeyi koru."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "进步是缓慢的，但失去却是瞬间的。保护您所构建的内容。"
          }
        }
      }
    },
    "mq_quote_5" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قرار واحد سيء يمكن أن يعيد ضبط كل شيء. البقاء في السيطرة الآن."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine schlechte Entscheidung kann alles auf den Kopf stellen. Behalten Sie jetzt die Kontrolle."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "One day at a time. One moment at a time. That's all it takes."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Una mala decisión puede reiniciar todo. Mantén el control ahora mismo.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Une mauvaise décision peut tout réinitialiser. Gardez le contrôle dès maintenant."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一つの間違った決断がすべてをリセットしてしまう可能性があります。今すぐコントロールしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "하나의 잘못된 결정이 모든 것을 재설정할 수 있습니다. 지금 바로 제어하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uma má decisão pode redefinir tudo. Mantenha o controle agora."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Одно неверное решение может все обнулить. Оставайтесь под контролем прямо сейчас."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kötü bir karar her şeyi sıfırlayabilir. Şu an kontrolü elinde tut."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一个错误的决定可能会重置一切。现在就保持控制。"
          }
        }
      }
    },
    "mq_quote_6" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سوف تشكرك نفسك المستقبلية على بقائك قوياً في هذه اللحظة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihr zukünftiges Ich wird Ihnen dafür danken, dass Sie in diesem Moment stark bleiben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your future self will thank you for the decision you made today."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Tu yo del futuro te agradecerá por mantenerte fuerte en este momento.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre futur moi vous remerciera d’être resté fort en ce moment."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "未来のあなたは、今この瞬間も強くいてくれたことに感謝するでしょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "미래의 당신의 모습은 지금 이 순간에도 강인함을 유지해준 당신에게 감사할 것입니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seu eu futuro agradecerá por permanecer forte neste momento."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваше будущее «я» поблагодарит вас за то, что вы остались сильными в этот момент."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gelecekteki sen, şu an güçlü kaldığın için sana teşekkür edecek."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "未来的你会感谢你在这一刻保持坚强。"
          }
        }
      }
    },
    "mq_quote_7" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذا هو المكان الذي استقال فيه معظم الناس. لا تكن مثل معظم الناس."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hier geben die meisten Leute auf. Sei nicht wie die meisten Menschen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sobriety is the greatest gift you can give your family."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Aquí es donde la mayoría se rinde. No seas como la mayoría.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "C'est là que la plupart des gens abandonnent. Ne soyez pas comme la plupart des gens."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ここでほとんどの人が辞めてしまいます。ほとんどの人のようにならないでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여기서 대부분의 사람들이 그만 두었습니다. 대부분의 사람들처럼 되지 마십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "É aqui que a maioria das pessoas desiste. Não seja como a maioria das pessoas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Именно здесь большинство людей уходят. Не будьте такими, как большинство людей."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Çoğu insanın pes ettiği yer burası. Çoğu insan gibi olma."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这是大多数人放弃的地方。不要像大多数人一样。"
          }
        }
      }
    },
    "mq_quote_8" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنت أقرب من أي وقت مضى لتصبح ما تريد أن تكون."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie sind der Person, die Sie sein möchten, näher als je zuvor."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The only person you need to be better than is who you were yesterday."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Estás más cerca que nunca de convertirte en quien quieres ser.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous êtes plus près que jamais de devenir celui que vous voulez être."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたはなりたい自分にこれまで以上に近づいています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신은 당신이 원하는 사람이 되는 데 그 어느 때보다 가까워졌습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você está mais perto do que nunca de se tornar quem deseja ser."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы ближе, чем когда-либо, к тому, чтобы стать тем, кем хотите быть."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Olmak istediğin kişiye hiç olmadığın kadar yakınsın."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你比以往任何时候都更接近成为你想成为的人。"
          }
        }
      }
    },
    "mq_quote_9" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كل يوم إضافي يهم أكثر مما تعتقد. لا تتوقف الآن."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeder zusätzliche Tag ist wichtiger als Sie denken. Hör jetzt nicht auf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Courage is not the absence of fear — it's acting in spite of it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Cada día extra importa más de lo que crees. No te detengas ahora.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaque jour supplémentaire compte plus que vous ne le pensez. Ne vous arrêtez pas maintenant."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "余分な 1 日が思っている以上に重要です。今はやめないでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "매일의 추가 하루는 당신이 생각하는 것보다 더 중요합니다. 지금 멈추지 마세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada dia extra é mais importante do que você pensa. Não pare agora."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Каждый дополнительный день значит больше, чем вы думаете. Не останавливайся сейчас."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Her fazladan gün düşündüğünden daha önemli. Şimdi durma."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每多一天都比你想象的更重要。现在不要停下来。"
          }
        }
      }
    },
    "mq_quote_10" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تبدو هذه الرغبة قوية، لكنها سوف تمر بشكل أسرع مما تعتقد. كن صبورا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieser Drang fühlt sich stark an, aber er wird schneller vergehen, als Sie denken. Bleiben Sie geduldig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Every morning is a new chance to change your life."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Este impulso se siente fuerte, pero pasará más rápido de lo que crees. Sé paciente.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette envie est forte, mais elle passera plus vite que vous ne le pensez. Restez patient."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この衝動は強く感じられますが、思っているよりも早く過ぎ去ります。我慢してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 충동은 강하게 느껴지지만 생각보다 빨리 지나갈 것입니다. 인내심을 가지십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esse desejo parece forte, mas passará mais rápido do que você pensa. Seja paciente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это желание кажется сильным, но оно пройдет быстрее, чем вы думаете. Будьте терпеливы."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu dürtü güçlü hissettiriyor ama düşündüğünden daha hızlı geçecek. Sabırlı ol."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这种冲动感觉很强烈，但它会比你想象的更快消失。保持耐心。"
          }
        }
      }
    },
    "mq_quote_11" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنت لا تحتاج إليها في الواقع، عقلك يطلب فقط الراحة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie brauchen es eigentlich nicht, Ihr Gehirn bittet nur um Trost."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You are not your addiction. You are stronger than it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"En realidad no lo necesitas, tu cerebro solo pide comodidad.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous n’en avez pas vraiment besoin, votre cerveau demande juste du réconfort."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "実際にはそれは必要なく、脳が快適さを求めているだけなのです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신은 실제로 그것이 필요하지 않습니다. 당신의 두뇌는 단지 편안함을 요구하고 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Na verdade, você não precisa disso, seu cérebro está apenas pedindo conforto."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "На самом деле вам это не нужно, ваш мозг просто просит утешения."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aslında buna ihtiyacın yok, beynin sadece rahatlık arıyor."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你实际上并不需要它，你的大脑只是在寻求安慰。"
          }
        }
      }
    },
    "mq_quote_12" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الحوافز مؤقتة، لكن الندم يدوم لفترة أطول. اختر بحكمة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Drang ist vorübergehend, aber das Bedauern hält viel länger an. Wählen Sie mit Bedacht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The pain of discipline is far less than the pain of regret."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Los impulsos son temporales, pero el arrepentimiento dura mucho más. Elige sabiamente.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les envies sont temporaires, mais les regrets durent beaucoup plus longtemps. Choisissez judicieusement."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "衝動は一時的なものですが、後悔はずっと長く続きます。賢明に選択してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "충동은 일시적이지만 후회는 훨씬 더 오래 지속됩니다. 현명하게 선택하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os impulsos são temporários, mas o arrependimento dura muito mais tempo. Escolha sabiamente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Побуждения временны, но сожаление длится гораздо дольше. Выбирайте мудро."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dürtüler geçicidir ama pişmanlık çok daha uzun sürer. Seçimini akıllıca yap."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "冲动是暂时的，但遗憾会持续更长时间。明智地选择。"
          }
        }
      }
    },
    "mq_quote_13" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "امنح نفسك 10 دقائق. تختفي معظم الحوافز إذا انتظرت."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gönnen Sie sich 10 Minuten. Die meisten Triebe verschwinden, wenn Sie warten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Believe you can, and you're halfway there."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Date 10 minutos. La mayoría de los impulsos desaparecen si esperas.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Donnez-vous 10 minutes. La plupart des envies disparaissent si vous attendez."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "10 分ほど時間をとってください。ほとんどの衝動は待っていれば消えます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "10분만 투자하세요. 대부분의 충동은 기다리면 사라집니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dê a si mesmo 10 minutos. A maioria dos impulsos desaparece se você esperar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дайте себе 10 минут. Большинство побуждений исчезнут, если вы подождете."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kendine 10 dakika ver. Beklersen çoğu dürtü kaybolur."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "给自己 10 分钟的时间。如果你等待，大多数冲动就会消失。"
          }
        }
      }
    },
    "mq_quote_14" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنت المسيطر، وليس رغباتك. تذكر ذلك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie haben die Kontrolle, nicht Ihr Verlangen. Denken Sie daran."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sobriety gives you everything alcohol promised."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Tú tienes el control, no tus antojos. Recuérdalo.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "C'est vous qui contrôlez, pas vos envies. Rappelez-vous cela."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "コントロールできるのは自分の欲求ではなく、あなたです。それを覚えておいてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신의 갈망이 아니라 당신이 통제할 수 있습니다. 그것을 기억하십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você está no controle, não seus desejos. Lembre-se disso."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы контролируете ситуацию, а не свои пристрастия. Помните об этом."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kontrol senin elinde, arzularının değil. Bunu unutma."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一切都在你的掌控之中，而不是你的渴望。请记住这一点。"
          }
