    "mq_quote_21" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الانضباط هو القيام بما يجب القيام به، حتى عندما لا تشعر بذلك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disziplin bedeutet, das zu tun, was getan werden muss, auch wenn man keine Lust dazu hat."
