          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Этот момент временный. Ваш прогресс - нет."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu an geçici. Ancak ilerlemen kalıcı."
          }
