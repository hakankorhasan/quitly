    "mq_quote_180" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "توقف للحظة. لا تحتاج إلى التصرف."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Halten Sie einen Moment inne. Sie müssen nicht handeln."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sobriety is self-love in action."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Haz una pausa por un momento. No necesitas actuar.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faites une pause un instant. Vous n’avez pas besoin d’agir."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ちょっと立ち止まってください。行動する必要はありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "잠시 멈춰보세요. 행동할 필요는 없습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faça uma pausa por um momento. Você não precisa agir."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сделайте паузу на мгновение. Вам не нужно действовать."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bir an durakla. Harekete geçmek zorunda değilsin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "暂停一下。你不需要采取行动。"
          }
        }
      }
    },
    "mq_quote_181" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تنفس بعمق واترك الشعور يمر."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atmen Sie tief durch und lassen Sie das Gefühl vergehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your emotions are real now. Feel them. Grow from them."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Respira profundamente y deja pasar el sentimiento.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Respirez profondément et laissez passer la sensation."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "深呼吸して、感情を解放してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "심호흡을 하고 느낌이 지나가도록 하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Respire profundamente e deixe o sentimento passar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дышите глубоко и позвольте этому чувству пройти."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Derin nefes al ve hissin geçmesine izin ver."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "深呼吸，让这种感觉过去。"
          }
