        }
      }
    },
    "mq_quote_151" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا تحتاج إلى التصرف على الفور. انتظر."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie müssen nicht sofort handeln. Warte ab."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You've already proved you're stronger than you thought."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"No necesitas actuar de inmediato. Espera.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous n’avez pas besoin d’agir tout de suite. Attendez."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すぐに行動する必要はありません。待ってください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당장 조치를 취할 필요는 없습니다. 기다려라."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você não precisa agir imediatamente. Espere."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не обязательно действовать сразу. Подождите."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
