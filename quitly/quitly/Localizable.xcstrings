        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたはもっとひどい対応をしました。それに比べればこれは何でもありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신은 더 나쁜 일을 처리했습니다. 그에 비하면 이건 아무것도 아니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você já lidou com coisas piores. Isso não é nada comparado a isso."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ты справился и похуже. Это ничто по сравнению с этим."
