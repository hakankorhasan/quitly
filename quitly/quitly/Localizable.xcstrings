        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Каждый раз, когда вы сопротивляетесь, вы обретаете настоящую силу."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Her direndiğinde, gerçek bir güç inşa ediyorsun."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每一次你的反抗，你都会积累真正的力量。"
          }
        }
      }
    },
    "mq_quote_25" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذه هي الطريقة التي يتم بها بناء الانضباط – قرار صعب واحد في كل مرة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "So entsteht Disziplin – eine schwere Entscheidung nach der anderen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recovery is about progression, not perfection."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Así se construye la disciplina: una decisión difícil a la vez.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "C’est ainsi que se construit la discipline : une décision difficile à la fois."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これが規律を築く方法であり、一度に 1 つの難しい決断を下す必要があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이것이 규율이 구축되는 방식입니다. 한 번에 하나의 어려운 결정을 내리는 것입니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "É assim que a disciplina é construída – uma decisão difícil de cada vez."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Именно так строится дисциплина — одно трудное решение за раз."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disiplin böyle inşa edilir; her seferinde zor bir karar vererek."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这就是纪律的建立方式——一次做出一个艰难的决定。"
          }
        }
      }
    },
    "mq_quote_26" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنت لست نفس الشخص الذي كنت عليه من قبل. لا ترجع إلى الوراء."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du bist nicht mehr derselbe Mensch wie vorher. Gehen Sie nicht zurück."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What lies behind us and what lies before us are tiny matters compared to what lies within us."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Ya no eres la misma persona que antes. No des marcha atrás.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous n’êtes plus la même personne qu’avant. Ne revenez pas en arrière."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたは以前と同じ人間ではありません。後戻りしないでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신은 이전과 같은 사람이 아닙니다. 뒤로 가지 마십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você não é a mesma pessoa que era antes. Não retroceda."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ты уже не тот человек, которым был раньше. Не идите назад."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Artık eskisi gibi değilsin. Geriye gitme."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你不再是以前的你了。不要后退。"
          }
        }
      }
    },
    "mq_quote_27" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الأشخاص الأقوياء لا يستسلمون عندما يصبح الأمر صعبًا. إنهم يدفعون من خلال."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Starke Menschen geben nicht auf, wenn es schwierig wird. Sie setzen sich durch."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sobriety isn't boring — it's freedom."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Las personas fuertes no se rinden cuando las cosas se ponen difíciles. Siguen adelante.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les gens forts n’abandonnent pas quand ça devient difficile. Ils passent au travers."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "強い人は苦しくても辞めません。彼らは押し通します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "강한 사람들은 힘들어도 포기하지 않습니다. 그들은 밀어붙인다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pessoas fortes não desistem quando fica difícil. Eles avançam."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сильные люди не сдаются, когда становится тяжело. Они прорываются."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Güçlü insanlar işler zorlaştığında pes etmezler. Sonuna kadar zorlarlar."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "坚强的人不会在遇到困难时放弃。他们挺过去了。"
          }
        }
      }
    },
    "mq_quote_28" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنت تقوم بتدريب عقلك الآن. لا تستسلم."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du trainierst gerade deinen Geist. Gib nicht auf."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your comeback story is being written right now."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Estás entrenando tu mente en este momento. No te rindas.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous entraînez votre esprit en ce moment. N'abandonnez pas."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたは今、心を鍛えています。あきらめないで。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신은 지금 마음을 훈련하고 있습니다. 포기하지 마세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você está treinando sua mente agora. Não desista."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы тренируете свой ум прямо сейчас. Не сдавайтесь."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Şu an zihnini eğitiyorsun. Pes etme."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你现在正在训练你的思想。不要放弃。"
          }
        }
      }
    },
    "mq_quote_29" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذا هو ما يشعر به النمو. إنه أمر غير مريح، لكنه يستحق ذلك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "So fühlt sich Wachstum an. Es ist unangenehm, aber es lohnt sich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Don't look back. You're not going that way."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Así se siente el crecimiento. Es incómodo, pero vale la pena.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Voilà à quoi ressemble la croissance. C'est inconfortable, mais ça vaut le coup."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "成長ってこういう感じなんですね。不快ですが、それだけの価値はあります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "성장이란 이런 느낌이다. 불편하지만 그만한 가치가 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "É assim que se sente o crescimento. É desconfortável, mas vale a pena."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вот что такое рост. Это неудобно, но оно того стоит."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Büyümek böyle hissettirir. Rahatsız edicidir ama buna değer."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这就是成长的感觉。这很不舒服，但值得。"
          }
        }
      }
    },
    "mq_quote_30" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا يستحق كل هذا العناء. لم يكن كذلك أبدا، ولن يكون أبدا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es lohnt sich nicht. Das war es nie und wird es auch nie sein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I am not what happened to me. I am what I choose to become."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"No vale la pena. Nunca lo fue y nunca lo será.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela n'en vaut pas la peine. Cela n’a jamais été le cas et cela ne le sera jamais."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "それは価値がありません。そんなことは決してなかったし、これからも決してないだろう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "그럴 가치가 없습니다. 그런 적은 없었고 앞으로도 없을 것입니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Não vale a pena. Nunca foi e nunca será."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это того не стоит. Этого никогда не было и никогда не будет."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buna değmez. Hiçbir zaman değmedi ve hiçbir zaman da değmeyecek."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这不值得。从来没有，也永远不会。"
          }
        }
      }
    },
    "mq_quote_31" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سوف تندم عليه لاحقا. ابق قويا الآن."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du wirst es später bereuen. Bleib jetzt stark."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Strength grows in the moments when you think you can't go on but you keep going anyway."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Te arrepentirás más tarde. Mantente fuerte ahora.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous le regretterez plus tard. Restez fort maintenant."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "後で後悔することになるでしょう。今はしっかりしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "나중에 후회하게 될 거예요. 이제 힘내세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você vai se arrepender mais tarde. Fique forte agora."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы пожалеете об этом позже. Оставайся сильным сейчас."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sonra pişman olacaksın. Şimdi güçlü kal."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你以后会后悔的。现在保持坚强。"
          }
        }
      }
    },
    "mq_quote_32" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سوف تمر هذه اللحظة، ولكن قرارك سيبقى معك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieser Moment wird vergehen, aber Ihre Entscheidung wird bei Ihnen bleiben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Every sober breath is a victory."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Este momento pasará, pero tu decisión se quedará contigo.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce moment passera, mais votre décision restera avec vous."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この瞬間は過ぎ去りますが、あなたの決断はあなたの中に残ります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 순간은 지나가겠지만, 당신의 결정은 당신의 마음에 남을 것입니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esse momento vai passar, mas a sua decisão ficará com você."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Этот момент пройдет, но ваше решение останется с вами."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu an geçecek ama kararın seninle kalacak."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这一刻将会过去，但你的决定将由你决定。"
          }
        }
      }
    },
    "mq_quote_33" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنت تعرف بالضبط ما ستشعر به بعد الاستسلام. لا تفعل ذلك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie wissen genau, wie Sie sich fühlen werden, wenn Sie nachgeben. Tun Sie es nicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The best time to plant a tree was 20 years ago. The second best time is now."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Sabes exactamente cómo te sentirás si cedes. No lo hagas.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous savez exactement ce que vous ressentirez après avoir cédé. Ne le faites pas."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "屈服した後にどう感じるかはあなたにもよくわかっています。そんなことはしないでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "포기한 후에 어떤 느낌이 들 것인지 정확히 알고 있습니다. 그러지 마십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você sabe exatamente como se sentirá depois de ceder."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы точно знаете, что почувствуете после того, как сдадитесь. Не делайте этого."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pes ettikten sonra nasıl hissedeceğini çok iyi biliyorsun. Bunu yapma."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你很清楚屈服后的感受。不要这样做。"
          }
        }
      }
    },
    "mq_quote_34" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اختر الكبرياء غداً بدلاً من الندم الليلة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entscheiden Sie sich morgen für Stolz statt heute Abend für Bedauern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You are worthy of a clear mind and a full heart."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Elige el orgullo mañana en lugar del arrepentimiento esta noche.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisissez la fierté demain au lieu du regret ce soir."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今夜後悔するのではなく、明日の誇りを選択してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "오늘 밤 후회보다는 내일 자부심을 선택하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escolha o orgulho amanhã em vez do arrependimento esta noite."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
