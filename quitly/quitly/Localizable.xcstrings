        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "もう少しだけ強くなってください。もうすぐそこです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "조금만 더 힘내세요. 거의 다 왔습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
