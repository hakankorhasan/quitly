        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"No eres débil. Tienes el control de tus elecciones.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous n'êtes pas faible. Vous êtes maître de vos choix."
