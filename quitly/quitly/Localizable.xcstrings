        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신은 이것을 처리할 수 있습니다. 침착하고 강해지십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
