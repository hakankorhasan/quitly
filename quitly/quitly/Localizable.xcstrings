    },
    "mq_quote_153" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كلما طالت مدة مقاومتك، أصبح الأمر أسهل."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je länger man Widerstand leistet, desto einfacher wird es."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your dopamine system is recalibrating. Better days are coming."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Cuanto más resistes, más fácil se vuelve.\","
          }
