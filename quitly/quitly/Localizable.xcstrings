    "mq_quote_59" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كن قوياً لمدة ساعة واحدة فقط."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bleiben Sie noch eine Stunde stark."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What seems like the end is often the beginning."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Mantente fuerte por solo una hora más.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restez fort pendant encore une heure."
