        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これはただあなたの心があなたを試しているだけです。テストに失敗しないでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이것은 단지 당신의 마음이 당신을 시험하는 것일 뿐입니다. 시험에 실패하지 마십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta é apenas a sua mente testando você. Não falhe no teste."
