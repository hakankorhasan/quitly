        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sobriety is a journey, not a destination."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"La parte más difícil es justo ahora. Supérala.\","
