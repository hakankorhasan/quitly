        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保持坚强一点点。你就快到了。"
          }
        }
      }
    },
    "mq_quote_156" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
