    "mq_quote_129": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay strong, you’re rewriting your story."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Mantente fuerte, estás reescribiendo tu historia.\","
          }
