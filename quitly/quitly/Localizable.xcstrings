        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "인내심을 가지십시오. 생각보다 잘하고 계시네요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seja paciente. Você está se saindo melhor do que pensa."
