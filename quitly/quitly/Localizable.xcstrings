    },
    "mq_quote_130": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is the exact moment where old habits try to come back. Don’t let them."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Este es el momento exacto donde los viejos hábitos intentan volver. No los dejes.\","
