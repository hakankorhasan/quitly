        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your future self is proud of you right now."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gelecekteki sen şu an seninle gurur duyuyor."
          }
        }
      }
    },
    "motivation_4": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This discomfort is temporary. Your freedom is permanent."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu rahatsızlık geçici. Özgürlüğün kalıcı."
          }
        }
      }
    },
    "motivation_5": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You didn't come this far to only come this far."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Buralara kadar sadece buralara kadar gelmek için gelmedin."
          }
        }
      }
    },
    "motivation_6": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One day at a time. You've got this."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her seferinde bir gün. Bunu başarabilirsin."
          }
        }
      }
    },
    "motivation_7": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The craving will pass. Your strength won't."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Arzu geçecek. Gücün geçmeyecek."
          }
        }
      }
    },
    "motivation_8": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Breathe. You are doing amazing."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nefes al. Harika gidiyorsun."
          }
        }
      }
    },
    "motivation_9": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every day clean is a gift to your body."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Temiz geçen her gün bedenine bir hediye."
          }
        }
      }
    },
    "motivation_10": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your streak is proof of your strength."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Serin, gücünün kanıtıdır."
          }
        }
      }
    },
    "motivation_daily_title": {
      "comment": "Daily Motivation",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Daily Motivation"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Günlük Motivasyon"
          }
        }
      }
    },
    "motivation_show_less": {
      "comment": "Show less",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Show less"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Daha az"
          }
        }
      }
    },
    "motivation_show_more": {
      "comment": "Show more",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Show more"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Daha fazla"
          }
        }
      }
    },
    "mq_quote_0": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You’ve come too far to quit now. Don’t let a moment destroy your progress."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Has llegado demasiado lejos para rendirte ahora. No dejes que un momento destruya tu progreso.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Şimdi bırakmak için çok fazla yol kat ettin. Bir anlık zayıflığın ilerlemeni mahvetmesine izin verme."
          }
        }
      }
    },
    "mq_quote_1": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every day you stay strong, you’re building a better version of yourself."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Cada día que te mantienes fuerte, estás construyendo una mejor versión de ti mismo.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Güçlü kaldığın her gün, kendinin daha iyi bir versiyonunu inşa ediyorsun."
          }
        }
      }
    },
    "mq_quote_2": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This streak is proof of your discipline. Don’t break it for a temporary feeling."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Esta racha es prueba de tu disciplina. No la rompas por un sentimiento temporal.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu seri senin disiplininin kanıtı. Geçici bir his için onu bozma."
          }
        }
      }
    },
    "mq_quote_3": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You didn’t come this far just to start over again. Keep going."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"No llegaste tan lejos solo para empezar de nuevo. Sigue adelante.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Buraya kadar sadece en baştan başlamak için gelmedin. Devam et."
          }
        }
      }
    },
    "mq_quote_4": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Progress is slow, but losing it is instant. Protect what you’ve built."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"El progreso es lento, pero perderlo es instantáneo. Protege lo que has construido.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İlerleme yavaştır, ancak onu kaybetmek an meselesidir. İnşa ettiğin şeyi koru."
          }
        }
      }
    },
    "mq_quote_5": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One bad decision can reset everything. Stay in control right now."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Una mala decisión puede reiniciar todo. Mantén el control ahora mismo.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kötü bir karar her şeyi sıfırlayabilir. Şu an kontrolü elinde tut."
          }
        }
      }
    },
    "mq_quote_6": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your future self will thank you for staying strong in this moment."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Tu yo del futuro te agradecerá por mantenerte fuerte en este momento.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gelecekteki sen, şu an güçlü kaldığın için sana teşekkür edecek."
          }
        }
      }
    },
    "mq_quote_7": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is where most people quit. Don’t be like most people."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Aquí es donde la mayoría se rinde. No seas como la mayoría.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Çoğu insanın pes ettiği yer burası. Çoğu insan gibi olma."
          }
        }
      }
    },
    "mq_quote_8": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are closer than ever to becoming who you want to be."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Estás más cerca que nunca de convertirte en quien quieres ser.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Olmak istediğin kişiye hiç olmadığın kadar yakınsın."
          }
        }
      }
    },
    "mq_quote_9": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every extra day matters more than you think. Don’t stop now."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Cada día extra importa más de lo que crees. No te detengas ahora.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her fazladan gün düşündüğünden daha önemli. Şimdi durma."
          }
        }
      }
    },
    "mq_quote_10": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This urge feels strong, but it will pass faster than you think. Stay patient."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Este impulso se siente fuerte, pero pasará más rápido de lo que crees. Sé paciente.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu dürtü güçlü hissettiriyor ama düşündüğünden daha hızlı geçecek. Sabırlı ol."
          }
        }
      }
    },
    "mq_quote_11": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You don’t actually need it, your brain is just asking for comfort."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"En realidad no lo necesitas, tu cerebro solo pide comodidad.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aslında buna ihtiyacın yok, beynin sadece rahatlık arıyor."
          }
        }
      }
    },
    "mq_quote_12": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Urges are temporary, but regret lasts much longer. Choose wisely."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Los impulsos son temporales, pero el arrepentimiento dura mucho más. Elige sabiamente.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dürtüler geçicidir ama pişmanlık çok daha uzun sürer. Seçimini akıllıca yap."
          }
        }
      }
    },
    "mq_quote_13": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Give yourself 10 minutes. Most urges disappear if you wait."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Date 10 minutos. La mayoría de los impulsos desaparecen si esperas.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kendine 10 dakika ver. Beklersen çoğu dürtü kaybolur."
          }
        }
      }
    },
    "mq_quote_14": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are in control, not your cravings. Remember that."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Tú tienes el control, no tus antojos. Recuérdalo.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kontrol senin elinde, arzularının değil. Bunu unutma."
          }
        }
      }
    },
    "mq_quote_15": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Just because you feel it doesn’t mean you have to act on it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Solo porque lo sientas no significa que debas actuar en consecuencia.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sırf hissediyorsun diye ona göre hareket etmek zorunda değilsin."
          }
        }
      }
    },
    "mq_quote_16": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is just your mind testing you. Don’t fail the test."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Esto es solo tu mente poniéndote a prueba. No repruebes la prueba.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu sadece zihninin seni test etmesi. Sınavda başarısız olma."
          }
        }
      }
    },
    "mq_quote_17": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The urge is loud, but your discipline must be louder."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"El impulso es ruidoso, pero tu disciplina debe serlo aún más.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dürtünün sesi yüksek olabilir ama disiplininin sesi daha yüksek olmalı."
          }
        }
      }
    },
    "mq_quote_18": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pause, breathe, and let this moment pass. You’ve done it before."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Haz una pausa, respira y deja pasar este momento. Ya lo has hecho antes.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Durakla, nefes al ve bu anın geçmesine izin ver. Bunu daha önce yaptın."
          }
        }
      }
    },
    "mq_quote_19": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You’ve beaten this feeling before. You can do it again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Has vencido este sentimiento antes. Puedes hacerlo de nuevo.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu hissi daha önce yendin. Tekrar yapabilirsin."
          }
        }
      }
    },
    "mq_quote_20": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are becoming someone who doesn’t give in easily. Keep proving it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Te estás convirtiendo en alguien que no cede fácilmente. Sigue demostrándolo.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kolayca pes etmeyen birine dönüşüyorsun. Bunu kanıtlamaya devam et."
          }
        }
      }
    },
    "mq_quote_21": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Discipline is doing what needs to be done, even when you don’t feel like it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"La disciplina es hacer lo que se debe hacer, incluso cuando no tienes ganas.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Disiplin, canın istemese bile yapılması gerekeni yapmaktır."
          }
        }
      }
    },
    "mq_quote_22": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is your moment to prove how strong you really are."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Este es tu momento de demostrar lo fuerte que realmente eres.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gerçekte ne kadar güçlü olduğunu kanıtlama anın işte bu."
          }
        }
      }
    },
    "mq_quote_23": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are not weak. You are in control of your choices."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"No eres débil. Tienes el control de tus elecciones.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Zayıf değilsin. Seçimlerinin kontrolü sende."
          }
        }
      }
    },
    "mq_quote_24": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every time you resist, you build real strength."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Cada vez que te resistes, construyes verdadera fuerza.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her direndiğinde, gerçek bir güç inşa ediyorsun."
          }
        }
      }
    },
    "mq_quote_25": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is how discipline is built—one hard decision at a time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Así se construye la disciplina: una decisión difícil a la vez.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Disiplin böyle inşa edilir; her seferinde zor bir karar vererek."
          }
        }
      }
    },
    "mq_quote_26": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You’re not the same person you were before. Don’t go backwards."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Ya no eres la misma persona que antes. No des marcha atrás.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Artık eskisi gibi değilsin. Geriye gitme."
          }
        }
      }
    },
    "mq_quote_27": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Strong people don’t quit when it gets hard. They push through."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Las personas fuertes no se rinden cuando las cosas se ponen difíciles. Siguen adelante.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Güçlü insanlar işler zorlaştığında pes etmezler. Sonuna kadar zorlarlar."
          }
        }
      }
    },
    "mq_quote_28": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are training your mind right now. Don’t give up."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Estás entrenando tu mente en este momento. No te rindas.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Şu an zihnini eğitiyorsun. Pes etme."
          }
        }
      }
    },
    "mq_quote_29": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is what growth feels like. It’s uncomfortable, but worth it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Así se siente el crecimiento. Es incómodo, pero vale la pena.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Büyümek böyle hissettirir. Rahatsız edicidir ama buna değer."
          }
        }
      }
    },
    "mq_quote_30": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It’s not worth it. It never was, and it never will be."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"No vale la pena. Nunca lo fue y nunca lo será.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Buna değmez. Hiçbir zaman değmedi ve hiçbir zaman da değmeyecek."
          }
        }
      }
    },
    "mq_quote_31": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You’ll regret it later. Stay strong now."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Te arrepentirás más tarde. Mantente fuerte ahora.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sonra pişman olacaksın. Şimdi güçlü kal."
          }
        }
      }
    },
    "mq_quote_32": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This moment will pass, but your decision will stay with you."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Este momento pasará, pero tu decisión se quedará contigo.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu an geçecek ama kararın seninle kalacak."
          }
        }
      }
    },
    "mq_quote_33": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You know exactly how you’ll feel after giving in. Don’t do it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Sabes exactamente cómo te sentirás si cedes. No lo hagas.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pes ettikten sonra nasıl hissedeceğini çok iyi biliyorsun. Bunu yapma."
          }
        }
      }
    },
    "mq_quote_34": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose pride tomorrow instead of regret tonight."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Elige el orgullo mañana en lugar del arrepentimiento esta noche.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu geceki pişmanlık yerine yarınki gururu seç."
          }
        }
      }
    },
    "mq_quote_35": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Don’t trade your progress for a few minutes of relief."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"No cambies tu progreso por unos minutos de alivio.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İlerlemeni birkaç dakikalık rahatlama için feda etme."
          }
        }
      }
    },
    "mq_quote_36": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You deserve better than falling back into old habits."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Mereces algo mejor que recaer en viejos hábitos.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Eski alışkanlıklara geri dönmekten daha iyisini hak ediyorsun."
          }
        }
      }
    },
    "mq_quote_37": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay strong now so you can feel proud later."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Mantente fuerte ahora para poder sentirte orgulloso después.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Daha sonra gurur duyabilmek için şimdi güçlü kal."
          }
        }
      }
    },
    "mq_quote_38": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is a small moment in a much bigger journey."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Este es un pequeño momento en un viaje mucho más grande.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu, çok daha büyük bir yolculukta küçük bir an."
          }
        }
      }
    },
    "mq_quote_39": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Don’t let a weak moment define you."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"No dejes que un momento de debilidad te defina.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Zayıf bir anın seni tanımlamasına izin verme."
          }
        }
      }
    },
    "mq_quote_40": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Take a deep breath. You don’t need to react immediately."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Respira profundo. No necesitas reaccionar de inmediato.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Derin bir nefes al. Hemen tepki vermek zorunda değilsin."
          }
        }
      }
    },
    "mq_quote_41": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Slow down. This feeling will pass if you give it time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Ve más despacio. Este sentimiento pasará si le das tiempo.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yavaşla. Zaman verirsen bu his geçecek."
          }
        }
      }
    },
    "mq_quote_42": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are safe. You are okay. Just breathe and stay present."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Estás a salvo. Estás bien. Solo respira y mantente presente.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Güvendesin. İyisin. Sadece nefes al ve anda kal."
          }
        }
      }
    },
    "mq_quote_43": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not every thought deserves a reaction. Let it go."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"No todo pensamiento merece una reacción. Déjalo ir.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Her düşünce bir tepkiyi hak etmez. Bırak gitsin."
          }
        }
      }
    },
    "mq_quote_44": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay calm and observe the feeling without acting on it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Mantén la calma y observa el sentimiento sin actuar.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sakin ol ve harekete geçmeden o hissi gözlemle."
          }
        }
      }
    },
    "mq_quote_45": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are not your thoughts. You are the one who controls them."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"No eres tus pensamientos. Eres quien los controla.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sen düşüncelerin değilsin. Sen onları kontrol edensin."
          }
        }
      }
    },
    "mq_quote_46": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Breathe in strength, breathe out the urge."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Inhala fuerza, exhala el impulso.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gücü içine çek, dürtüyü dışarı üfle."
          }
        }
      }
    },
    "mq_quote_47": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay grounded. This moment doesn’t control you."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Mantén los pies en la tierra. Este momento no te controla.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ayakların yere sağlam bassın. Bu an seni kontrol edemez."
          }
        }
      }
    },
    "mq_quote_48": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Calm your mind and trust your decision."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Calma tu mente y confía en tu decisión.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Zihnini sakinleştir ve kararına güven."
          }
        }
      }
    },
    "mq_quote_49": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Peace comes from control, not from giving in."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"La paz viene del control, no de rendirse.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Huzur pes etmekten değil, kontrolü elinde tutmaktan gelir."
          }
        }
      }
    },
    "mq_quote_50": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Starting over is harder than continuing. Don’t reset now."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Empezar de nuevo es más difícil que continuar. No reinicies ahora.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Baştan başlamak, devam etmekten daha zordur. Şimdi sıfırlama."
          }
        }
      }
    },
    "mq_quote_51": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You already know where going back leads. Choose forward."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Ya sabes a dónde lleva mirar atrás. Elige ir hacia adelante.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Geriye dönmenin nereye vardığını zaten biliyorsun. İleri gitmeyi seç."
          }
        }
      }
    },
    "mq_quote_52": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One mistake can undo days of effort. Stay focused."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Un error puede deshacer días de esfuerzo. Mantente enfocado.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir hata günlerce süren çabayı yok edebilir. Odaklan."
          }
        }
      }
    },
    "mq_quote_53": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Don’t break your promise to yourself."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"No rompas la promesa que te hiciste.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kendine verdiğin sözü bozma."
          }
        }
      }
    },
    "mq_quote_54": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You’ve worked too hard to throw it away now."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Has trabajado demasiado duro para tirarlo todo por la borda ahora.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Şimdi çöpe atmak için çok fazla çalıştın."
          }
        }
      }
    },
    "mq_quote_55": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You’re not missing anything by saying no."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"No te estás perdiendo de nada al decir \\\"no\\\".\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Hayır\" diyerek hiçbir şey kaçırmıyorsun."
          }
        }
      }
    },
    "mq_quote_56": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is just a test. Pass it and move forward."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Esto es solo una prueba. Pásala y sigue adelante.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu sadece bir test. Onu geç ve ilerlemeye devam et."
          }
        }
      }
    },
    "mq_quote_57": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You’ve made it this far. Don’t sabotage yourself."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Has llegado muy lejos. No te sabotees.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Buraya kadar geldin. Kendi kendini sabote etme."
          }
        }
      }
    },
    "mq_quote_58": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The hardest part is right now. Get through it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"La parte más difícil es justo ahora. Supérala.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "En zor kısım tam olarak şu an. Bunu atlat."
          }
        }
      }
    },
    "mq_quote_59": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay strong for just one more hour."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Mantente fuerte por solo una hora más.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sadece bir saat daha güçlü kal."
          }
        }
      }
    },
    "mq_quote_60": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You’ve invested time, effort, and energy into this. Don’t waste it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Has invertido tiempo, esfuerzo y energía en esto. No lo desperdicies.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Buna zaman, çaba ve enerji yatırdın. Boşa harcama."
          }
        }
      }
    },
    "mq_quote_61": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your progress has value. Protect it like it matters."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Tu progreso tiene valor. Protégelo como si importara.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İlerlemenin bir değeri var. Önemliymiş gibi onu koru."
          }
        }
      }
    },
    "mq_quote_62": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are saving more than money—you are saving your future."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Estás ahorrando más que dinero: estás salvando tu futuro.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Paradan daha fazlasını biriktiriyorsun; geleceğini kurtarıyorsun."
          }
        }
      }
    },
    "mq_quote_63": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every day you resist, you gain something valuable."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Cada día que resistes, ganas algo valioso.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Direndiğin her gün değerli bir şey kazanıyorsun."
          }
        }
      }
    },
    "mq_quote_64": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Don’t throw away something valuable for something temporary."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"No tires algo valioso por algo temporal.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Geçici bir şey için değerli bir şeyi çöpe atma."
          }
        }
      }
    },
    "mq_quote_65": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You’ve already paid the price. Don’t lose the reward."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Ya has pagado el precio. No pierdas la recompensa.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bedelini zaten ödedin. Ödülü kaybetme."
          }
        }
      }
    },
    "mq_quote_66": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What you’re building is worth more than this moment."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Lo que estás construyendo vale más que este momento.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İnşa ettiğin şey bu andan çok daha değerli."
          }
        }
      }
    },
    "mq_quote_67": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay committed to what truly matters."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Mantén tu compromiso con lo que realmente importa.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gerçekten önemli olana sadık kal."
          }
        }
      }
    },
    "mq_quote_68": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your future is more important than this urge."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Tu futuro es más importante que este impulso.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
