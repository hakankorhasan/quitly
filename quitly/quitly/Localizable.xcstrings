      }
    },
    "mq_quote_185" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ابقَ على الأرض. أنت أقوى من هذا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
