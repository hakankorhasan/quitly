    "mq_quote_35" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا تستبدل تقدمك ببضع دقائق من الراحة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tauschen Sie Ihre Fortschritte nicht gegen ein paar Minuten Erleichterung ein."
