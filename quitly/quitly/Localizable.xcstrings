        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dedication today. Celebration tomorrow."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Mantén los pies en la tierra. Eres más fuerte que esto.\","
