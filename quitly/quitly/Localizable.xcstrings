      }
    },
    "mq_quote_182" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ابقَ هادئًا. أنت المسيطر."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bleiben Sie ruhig. Sie haben die Kontrolle."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The person in the mirror is proud of you."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Mantén la calma. Tienes el control.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rester calme. Vous avez le contrôle."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "落ち着いてください。あなたがコントロールできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "침착하세요. 당신은 통제할 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fique calmo. Você está no controle."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сохраняйте спокойствие. Вы все контролируете."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sakin ol. Kontrol sende."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保持冷静。您一切尽在掌握。"
          }
        }
      }
    },
    "mq_quote_183" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذه مجرد لحظة. لا تعطيه السلطة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das ist nur ein Moment. Gib ihm keine Macht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Life is better when you remember all of it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Es solo un momento. No le des poder.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ceci n'est qu'un instant. Ne lui donnez pas de pouvoir."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これはほんの一瞬です。力を与えないでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이것은 단지 순간일 뿐입니다. 힘을 주지 마세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este é apenas um momento. Não dê poder a isso."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это всего лишь момент. Не давайте ему власти."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu sadece bir an. Ona güç verme."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这只是一瞬间。不要给它力量。"
          }
        }
      }
    },
    "mq_quote_184" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "دع الرغبة موجودة دون التصرف بناءً عليها."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lassen Sie den Drang bestehen, ohne ihm nachzugehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your heart rate is steadier. Your life is too."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Deja que el impulso exista sin actuar sobre él.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Laissez l’envie exister sans agir en conséquence."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "衝動は行動に移さずに存在させてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "충동에 따라 행동하지 않고 존재하게 하십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
