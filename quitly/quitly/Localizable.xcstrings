    "trigger_detail_empty_hint" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عندما تضغط ابق قويا أو انزلقت سنسألك لماذا وستظهر أنماطك هنا"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
