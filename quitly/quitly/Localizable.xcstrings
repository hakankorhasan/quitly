    "mq_quote_80" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لقد تعاملت مع ما هو أسوأ. وهذا لا شيء بالمقارنة مع ذلك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
