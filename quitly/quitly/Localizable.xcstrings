    "mq_quote_189" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "السلام يأتي من السيطرة، وليس من الاستسلام."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frieden entsteht durch Kontrolle, nicht durch Nachgeben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Never underestimate the power of 'no, thank you.'"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"La paz viene del control, no de rendirse.\","
