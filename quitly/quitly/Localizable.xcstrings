    "mq_quote_109" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "في كل مرة تقول لا، تصبح أقوى."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jedes Mal, wenn du Nein sagst, wirst du stärker."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You've survived 100% of your hardest days."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Cada vez que dices \\\"no\\\", te vuelves más fuerte.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaque fois que tu dis non, tu deviens plus fort."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「ノー」と言うたびに、あなたは強くなります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "거절할 때마다 당신은 더 강해진다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada vez que você diz não, você fica mais forte."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Каждый раз, когда ты говоришь «нет», ты становишься сильнее."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Hayır\" dediğin her an, daha da güçlenirsin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每一次你说不，你就会变得更坚强。"
          }
        }
      }
    },
    "mq_quote_110" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "فكر في سبب بدايتك. هذا السبب لا يزال يهم."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Denken Sie darüber nach, warum Sie angefangen haben. Dieser Grund ist immer noch wichtig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Patience with yourself is the ultimate kindness."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Piensa en por qué empezaste. Esa razón aún importa.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pensez à la raison pour laquelle vous avez commencé. Cette raison compte toujours."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "なぜ始めたのか考えてみましょう。その理由は今でも重要です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "왜 시작했는지 생각해 보세요. 그 이유는 여전히 중요합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pense por que você começou. Esse motivo ainda importa."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Подумайте, почему вы начали. Эта причина все еще имеет значение."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neden başladığını düşün. O sebep hâlâ geçerli."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "想想你为什么开始。这个理由仍然很重要。"
          }
        }
      }
    },
    "mq_quote_111" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا تحتاج إلى الرد على كل فكرة. دع هذا يمر."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie müssen nicht auf jeden Gedanken reagieren. Lass das durchgehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The longest journey begins beneath your feet."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"No necesitas reaccionar a cada pensamiento. Deja pasar este.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous n’avez pas besoin de réagir à chaque pensée. Laissez passer celui-ci."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべての考えに反応する必要はありません。これはスルーしましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모든 생각에 반응할 필요는 없습니다. 이건 통과시키세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você não precisa reagir a cada pensamento. Deixe este passar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вам не нужно реагировать на каждую мысль. Пусть это пройдет."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Her düşünceye tepki vermek zorunda değilsin. Bırak bu da geçip gitsin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你不需要对每个想法都做出反应。让这件事过去吧。"
          }
        }
      }
    },
    "mq_quote_112" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عقلك يحاول خداعك. لا تقع في غرامها."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein Verstand versucht dich auszutricksen. Fallen Sie nicht darauf herein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sober life is the high life."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Tu mente está intentando engañarte. No caigas en la trampa.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre esprit essaie de vous tromper. Ne tombez pas dans le piège."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたの心はあなたを騙そうとしています。騙されないでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신의 마음은 당신을 속이려고 노력하고 있습니다. 그것에 빠지지 마십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sua mente está tentando enganá-lo. Não caia nessa."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваш разум пытается вас обмануть. Не поддавайтесь этому."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zihnin seni kandırmaya çalışıyor. Bu tuzağa düşme."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的头脑正试图欺骗你。不要上当。"
          }
        }
      }
    },
    "mq_quote_113" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنت تعرف النتيجة بالفعل. اختر الأفضل هذه المرة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie kennen das Ergebnis bereits. Wählen Sie dieses Mal eine bessere Wahl."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Let your recovery inspire others."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Ya conoces el resultado. Elige mejor esta vez.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous connaissez déjà le résultat. Choisissez mieux cette fois."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたはすでに結果を知っています。今度はもっと良いものを選んでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신은 이미 결과를 알고 있습니다. 이번에는 더 나은 것을 선택하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você já sabe o resultado. Escolha melhor desta vez."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы уже знаете результат. На этот раз выбери лучше."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sonucun ne olacağını zaten biliyorsun. Bu kez daha iyisini seç."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你已经知道结果了。这次选择更好。"
          }
        }
      }
    },
    "mq_quote_114" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذا لا يستحق كسر تقدمك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das ist es nicht wert, Ihren Fortschritt zu unterbrechen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You chose difficult over destructive. That's brave."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"No vale la pena arruinar tu progreso por esto.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela ne vaut pas la peine d’interrompre votre progression."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これであなたの進歩を妨げる価値はありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이것은 진행 상황을 깨뜨릴 가치가 없습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Não vale a pena interromper seu progresso."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это не стоит того, чтобы ломать ваш прогресс."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu, ilerlemeni bozmaya değmez."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这不值得破坏你的进步。"
          }
        }
      }
    },
    "mq_quote_115" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كن واعيًا باللحظة بدلًا من أن تسيطر عليها."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seien Sie sich des Augenblicks bewusst, anstatt ihn zu kontrollieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The urge is temporary. The regret is not."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Sé consciente del momento en lugar de ser controlado por él.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soyez conscient du moment au lieu de le contrôler."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "その瞬間にコントロールされるのではなく、その瞬間に気づいてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "순간에 통제당하기보다는 순간을 인식하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esteja ciente do momento em vez de ser controlado por ele."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Осознавайте момент, а не контролируйте его."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anın seni kontrol etmesine izin vermek yerine anın farkında ol."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "意识到当下而不是被它控制。"
          }
        }
      }
    },
    "mq_quote_116" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أفكارك لا تتحكم بك. أفعالك تفعل."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Gedanken kontrollieren dich nicht. Ihre Taten tun es."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You are rewriting your story."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Tus pensamientos no te controlan. Tus acciones sí.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vos pensées ne vous contrôlent pas. Vos actions le font."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたの考えがあなたをコントロールすることはありません。あなたの行動はそうなります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신의 생각은 당신을 통제하지 않습니다. 당신의 행동은 그렇습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seus pensamentos não controlam você. Suas ações sim."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваши мысли не контролируют вас. Ваши действия имеют значение."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Düşüncelerin seni kontrol etmez. Eylemlerin eder."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的想法无法控制你。你的行动确实如此。"
          }
        }
      }
    },
    "mq_quote_117" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذا مجرد ضجيج. استمر في التركيز على هدفك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das ist nur Lärm. Konzentrieren Sie sich auf Ihr Ziel."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your organs are regenerating. Science says so."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Esto es solo ruido. Mantente enfocado en tu objetivo.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce n'est que du bruit. Restez concentré sur votre objectif."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これは単なるノイズです。目標に集中してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이것은 단지 소음일 뿐입니다. 목표에 계속 집중하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isso é apenas barulho. Mantenha o foco em seu objetivo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это просто шум. Оставайтесь сосредоточенными на своей цели."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu sadece bir gürültü. Hedefine odaklı kal."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这只是噪音。专注于你的目标。"
          }
        }
      }
    },
    "mq_quote_118" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ابق واعيا. لا تتصرف على أساس الاندفاع."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bleiben Sie bei Bewusstsein. Handeln Sie nicht aus einem Impuls heraus."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The hardest walk you can make is the walk you make alone. But it's the walk that makes you the strongest."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Mantente consciente. No actúes por impulso.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Restez conscient. N’agissez pas par impulsion."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "意識を保ってください。衝動的に行動しないでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "의식을 유지하세요. 충동적으로 행동하지 마십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fique consciente. Não aja por impulso."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Оставайтесь в сознании. Не действуйте импульсивно."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bilincini açık tut. Dürtüyle hareket etme."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保持清醒。不要冲动行事。"
          }
        }
      }
    },
    "mq_quote_119" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اتخذ قرارًا ستحترمه نفسك في المستقبل."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
