        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clean blood, clear mind, calm heart."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Has lidiado con cosas peores. Esto no es nada en comparación.\","
