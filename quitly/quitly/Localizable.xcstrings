    "mq_quote_123" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتم بناء القوة في لحظات مثل هذه. لا تضيعه."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
