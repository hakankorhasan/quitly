    "mq_quote_36" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنت تستحق أفضل من العودة إلى العادات القديمة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
