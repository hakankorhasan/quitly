    "mq_quote_174" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ابق متسقًا. هذا هو المكان الذي يعيش فيه النجاح."
