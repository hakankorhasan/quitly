    "relapse_support_message" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كل تعثر هو جزء من الرحلة. اليوم هو بداية جديدة. لقد حصلت على هذا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jedes Stolpern ist Teil der Reise. Heute ist ein Neuanfang. Du hast das."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Every stumble is part of the journey. Today is a new beginning. You've got this."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaque faux pas fait partie du voyage. Aujourd'hui, c'est un nouveau départ. Vous avez ça."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべてのつまずきは旅の一部です。今日は新たな始まりです。これを持っていますね。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모든 넘어짐은 여행의 일부입니다. 오늘은 새로운 시작입니다. 당신은 이것을 가지고 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada tropeço faz parte da jornada. Hoje é um novo começo. Você tem isso."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Каждое спотыкание – это часть пути. Сегодня новое начало. У вас есть это."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Her tökezleme yolculuğun bir parçası. Bugün yeni bir başlangıç. Bunu başaracaksın."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每一次绊倒都是旅程的一部分。今天是一个新的开始。你已经得到了这个。"
          }
        }
      }
    },
