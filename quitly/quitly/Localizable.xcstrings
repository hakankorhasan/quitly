    "mq_quote_106" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنت لا تنكر نفسك، بل تقوم بترقية نفسك."
