    "mq_quote_188": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay present. This will pass."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Mantente presente. Esto pasará.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Anda kal. Bu da geçecek."
          }
        }
      }
    },
    "mq_quote_189": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Peace comes from control, not from giving in."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"La paz viene del control, no de rendirse.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Huzur pes etmekten değil, kontrolü elinde tutmaktan gelir."
          }
        }
      }
    },
    "mq_quote_190": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Just get through this moment. That’s enough."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Solo supera este momento. Con eso es suficiente.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sadece bu anı atlat. Bu kadarı yeterli."
          }
        }
      }
    },
    "mq_quote_191": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stay strong for the next few minutes. You can do it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Mantente fuerte por los próximos minutos. Tú puedes hacerlo.\","
          }
