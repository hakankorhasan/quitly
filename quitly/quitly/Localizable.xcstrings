        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Önümüzdeki birkaç dakika boyunca güçlü kal. Bunu yapabilirsin."
          }
        }
      }
    },
    "mq_quote_192": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One small decision right now changes your future."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Una pequeña decisión ahora mismo cambia tu futuro.\","
          }
