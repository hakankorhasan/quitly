    "settings_reset_alert_message" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي هذا إلى حذف عادتك وخطك. لا يمكن التراجع عن هذا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden Ihre Gewohnheit und Ihr Streak gelöscht. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will delete your habit and streak. This cannot be undone."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprimera votre habitude et votre séquence. Cela ne peut pas être annulé."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これにより、あなたの習慣と縞模様が削除されます。これを元に戻すことはできません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "습관과 연속 기록이 삭제됩니다. 이 작업은 취소할 수 없습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isso excluirá seu hábito e sequência. Isto não pode ser desfeito."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это удалит вашу привычку и полосу. Это невозможно отменить."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu, alışkanlığını ve serini silecek. Geri alınamaz."
