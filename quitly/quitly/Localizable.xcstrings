    "mq_quote_37" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كن قوياً الآن حتى تشعر بالفخر لاحقاً."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bleiben Sie jetzt stark, damit Sie später stolz sein können."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The darker the night, the brighter the stars."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Mantente fuerte ahora para poder sentirte orgulloso después.\","
