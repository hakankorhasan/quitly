    "mq_quote_24" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "في كل مرة تقاوم فيها، فإنك تبني قوة حقيقية."
