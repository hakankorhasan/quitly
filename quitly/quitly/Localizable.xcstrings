    },
    "mq_quote_125": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This moment doesn’t define you, your decision does."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Este momento no te define, tu decisión sí.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu an seni tanımlamaz, kararların tanımlar."
          }
