    "mq_quote_100" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الانضباط هو اختيار ما تريده أكثر من ما تريده الآن. حافظ على تركيزك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disziplin bedeutet, das zu wählen, was Sie am meisten wollen, und nicht das, was Sie jetzt wollen. Bleiben Sie konzentriert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Peace of mind is priceless."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"La disciplina es elegir lo que más quieres por encima de lo que quieres ahora. Mantente enfocado.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La discipline consiste à choisir ce que vous voulez le plus plutôt que ce que vous voulez maintenant. Restez concentré."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "規律とは、今望むものよりも最も望むものを選択することです。集中力を維持しましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "징계는 지금 ​​원하는 것보다 가장 원하는 것을 선택하는 것입니다. 집중하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disciplina é escolher o que você mais deseja em vez do que deseja agora. Mantenha o foco."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дисциплина — это выбор того, чего вы хотите больше всего, а не того, что вы хотите сейчас. Оставайтесь сосредоточенными."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disiplin, şu an istediğin şey yerine en çok istediğin şeyi seçmektir. Odaklan."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自律就是选择你最想要的而不是你现在想要的。保持专注。"
          }
        }
      }
    },
    "mq_quote_101" : {
      "extractionState" : "stale",
