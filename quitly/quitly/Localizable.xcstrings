    },
    "mq_quote_132": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You don’t need to repeat the same mistake again."
          }
        },
        "es": {
          "stringUnit": {
