    "mq_quote_18" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "توقف، تنفس، ودع هذه اللحظة تمر. لقد فعلت ذلك من قبل."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Halten Sie inne, atmen Sie und lassen Sie diesen Moment vergehen. Du hast es schon einmal getan."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The greatest glory is not in never falling, but in rising every time we fall."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Haz una pausa, respira y deja pasar este momento. Ya lo has hecho antes.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faites une pause, respirez et laissez passer ce moment. Vous l’avez déjà fait."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "立ち止まって、深呼吸して、この瞬間を過ぎましょう。前にもやったことがありますね。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "잠시 멈추고, 숨을 쉬고, 이 순간이 지나가도록 하세요. 당신은 전에 그것을 해본 적이 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faça uma pausa, respire e deixe esse momento passar. Você já fez isso antes."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сделайте паузу, вдохните и позвольте этому моменту пройти. Вы уже делали это раньше."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durakla, nefes al ve bu anın geçmesine izin ver. Bunu daha önce yaptın."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "暂停，呼吸，让这一刻过去。你以前已经做过了。"
          }
        }
      }
    },
    "mq_quote_19" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لقد تغلبت على هذا الشعور من قبل. يمكنك أن تفعل ذلك مرة أخرى."
