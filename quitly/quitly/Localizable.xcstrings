      }
    },
    "mq_quote_122": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You’ve survived worse than this. Keep going."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"Has sobrevivido a cosas peores. Sigue adelante.\","
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bundan daha kötülerini atlattın. Devam et."
          }
        }
      }
    },
    "mq_quote_123": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Strength is built in moments like this. Don’t waste it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"La fuerza se construye en momentos como este. No lo desperdicies.\","
          }
