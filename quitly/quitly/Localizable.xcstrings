        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "가장 어려운 부분은 바로 지금이다. 그것을 극복하십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A parte mais difícil é agora. Supere isso."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Самое сложное сейчас. Пройди через это."
          }
        },
