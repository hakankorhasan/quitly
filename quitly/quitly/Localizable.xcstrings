    "mq_quote_148" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمكنك التعامل مع هذا. ابقَ هادئًا وقويًا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie können damit umgehen. Bleib ruhig und stark."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Happiness is not at the bottom of a glass."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Puedes manejar esto. Mantente tranquilo y fuerte.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous pouvez gérer cela. Restez calme et fort."
