        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "再坚持一小时。"
          }
        }
      }
    },
    "mq_quote_60" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لقد استثمرت الوقت والجهد والطاقة في هذا. لا تضيعه."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie haben Zeit, Mühe und Energie investiert. Verschwende es nicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You are one decision away from a completely different life."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Has invertido tiempo, esfuerzo y energía en esto. No lo desperdicies.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous y avez investi du temps, des efforts et de l’énergie. Ne le gaspillez pas."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたはこれに時間、努力、エネルギーを投資してきました。無駄にしないでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신은 여기에 시간, 노력, 에너지를 투자했습니다. 낭비하지 마십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você investiu tempo, esforço e energia nisso. Não desperdice isso."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы вложили в это время, усилия и энергию. Не тратьте его зря."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buna zaman, çaba ve enerji yatırdın. Boşa harcama."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您为此投入了时间、精力和精力。不要浪费它。"
          }
        }
      }
    },
    "mq_quote_61" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تقدمك له قيمة. قم بحمايته كما هو مهم."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihr Fortschritt ist wertvoll. Schützen Sie es, als wäre es wichtig."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Don't count the days. Make the days count."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Tu progreso tiene valor. Protégelo como si importara.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vos progrès ont de la valeur. Protégez-le comme si c’était important."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたの進歩には価値があります。大事なことのように守りましょう。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "귀하의 발전은 가치가 있습니다. 중요한 것처럼 보호하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seu progresso tem valor. Proteja-o como se fosse importante."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваш прогресс имеет ценность. Защищайте его, как будто это важно."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "İlerlemenin bir değeri var. Önemliymiş gibi onu koru."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的进步是有价值的。保护它就像重要的事情一样。"
          }
        }
      }
    },
    "mq_quote_62" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنت تدخر أكثر من مجرد المال، فأنت تنقذ مستقبلك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie sparen mehr als nur Geld – Sie retten Ihre Zukunft."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Every expert was once a beginner. Every sober year started with day one."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Estás ahorrando más que dinero: estás salvando tu futuro.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous économisez plus que de l’argent : vous sauvez votre avenir."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたはお金を節約しているだけではなく、自分の将来を節約しているのです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신은 돈보다 더 많은 것을 절약하고 있습니다. 미래를 구하는 것입니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você está economizando mais do que dinheiro – você está salvando seu futuro."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы экономите больше, чем деньги — вы экономите свое будущее."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paradan daha fazlasını biriktiriyorsun; geleceğini kurtarıyorsun."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您节省的不仅仅是金钱——您正在拯救您的未来。"
          }
        }
      }
    },
    "mq_quote_63" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "في كل يوم تقاوم فيه، تكتسب شيئًا ذا قيمة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeden Tag, an dem Sie Widerstand leisten, gewinnen Sie etwas Wertvolles."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your best life is on the other side of this struggle."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Cada día que resistes, ganas algo valioso.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaque jour où vous résistez, vous gagnez quelque chose de précieux."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "抵抗するたびに、あなたは貴重なものを獲得します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "저항하는 날마다 귀중한 것을 얻게 됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada dia que você resiste, você ganha algo valioso."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Каждый день сопротивления вы приобретаете что-то ценное."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Direndiğin her gün değerli bir şey kazanıyorsun."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你每天抵抗，你就会收获一些有价值的东西。"
          }
        }
      }
    },
    "mq_quote_64" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا تتخلص من شيء ثمين مقابل شيء مؤقت."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Werfen Sie etwas Wertvolles nicht für etwas Vorübergehendes weg."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The struggle you're in today is developing the strength you need for tomorrow."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"No tires algo valioso por algo temporal.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ne jetez pas quelque chose de précieux pour quelque chose de temporaire."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一時的なもののために貴重なものを捨てないでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "일시적인 것을 위해 귀중한 것을 버리지 마십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Não jogue fora algo valioso por algo temporário."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не выбрасывайте что-то ценное ради чего-то временного."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geçici bir şey için değerli bir şeyi çöpe atma."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "不要为了暂时的东西而丢弃有价值的东西。"
          }
        }
      }
    },
    "mq_quote_65" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لقد دفعت الثمن بالفعل. لا تفقد المكافأة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie haben den Preis bereits bezahlt. Verliere die Belohnung nicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Addiction is giving up everything for one thing. Recovery is giving up one thing for everything."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Ya has pagado el precio. No pierdas la recompensa.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous en avez déjà payé le prix. Ne perdez pas la récompense."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたはすでに代金を支払いました。報酬を逃さないでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신은 이미 대가를 지불했습니다. 보상을 잃지 마십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você já pagou o preço. Não perca a recompensa."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы уже заплатили цену. Не теряйте награду."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bedelini zaten ödedin. Ödülü kaybetme."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
