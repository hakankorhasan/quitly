          "stringUnit" : {
            "state" : "translated",
            "value" : "Es ist in Ordnung, zu kämpfen. Wenn Sie Ihren Streak zurücksetzen, beginnt Ihre Reise neu."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "It's okay to struggle. Resetting your streak will start your journey fresh."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "C'est bien de lutter. Réinitialiser votre séquence commencera votre voyage à neuf."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "苦労しても大丈夫です。連続記録をリセットすると、新たな旅が始まります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "힘들어도 괜찮습니다. 연속 기록을 재설정하면 여행이 새롭게 시작됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Não há problema em lutar. Redefinir sua seqüência iniciará sua jornada do zero."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это нормально – бороться. Сброс вашей серии позволит начать ваше путешествие заново."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zorlanman çok normal. Serini sıfırladığında yolculuğuna temiz bir sayfa açmış olacaksın."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "挣扎一下也没关系。重置你的连胜纪录将让你的旅程重新开始。"
          }
        }
      }
    },
