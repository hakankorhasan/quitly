        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保持耐心。你做得比你想象的要好。"
          }
        }
      }
    },
    "mq_quote_159" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الوقت في صالحك. لا تتسرع في الخطأ."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Zeit ist auf Ihrer Seite. Machen Sie keinen Fehler."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You are not your worst moment."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"El tiempo está de tu lado. No te apresures a cometer un error.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le temps est de votre côté. Ne vous précipitez pas dans une erreur."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "時間は味方です。急いで間違いを犯さないでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "시간은 당신 편입니다. 서두르지 마십시오."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O tempo está do seu lado. Não se apresse em cometer um erro."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Время на вашей стороне. Не спешите совершать ошибку."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zaman senin lehine. Aceleyle bir hata yapma."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "时间站在你这边。不要急于犯错误。"
          }
        }
      }
    },
    "mq_quote_160" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لقد عملت بجد لتحقيق هذا التقدم. لا تضيعوه الآن."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie haben hart für diesen Fortschritt gearbeitet. Verschwenden Sie es jetzt nicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Each day sober is a revolution."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Has trabajado duro por este progreso. No lo desperdicies ahora.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous avez travaillé dur pour progresser. Ne le gaspillez pas maintenant."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたはこの進歩のために一生懸命働いてきました。今は無駄にしないでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 발전을 위해 열심히 일하셨습니다. 지금은 낭비하지 마세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você trabalhou duro para esse progresso. Não desperdice agora."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы много работали для достижения этого прогресса. Не тратьте его сейчас."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu ilerleme için çok çalıştın. Şimdi onu heba etme."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你们为这一进步付出了努力。现在不要浪费它。"
          }
        }
      }
    },
    "mq_quote_161" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذه الرحلة لها قيمة. التعامل معها كما لو أنها مهمة."
          }
        },
        "de" : {
          "stringUnit" : {
