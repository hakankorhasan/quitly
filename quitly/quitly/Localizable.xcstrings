        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你抵抗的时间越长，事情就越容易发生。"
          }
        }
      }
    },
    "mq_quote_154" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذه اللحظة مؤقتة. تقدمك ليس كذلك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieser Moment ist vorübergehend. Dein Fortschritt ist es nicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Replace the habit, not the void."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Este momento es temporal. Tu progreso no lo es.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
