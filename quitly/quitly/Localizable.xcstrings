        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ты справишься с этим. Оставайся спокойным и сильным."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bunun üstesinden gelebilirsin. Sakin ve güçlü kal."
