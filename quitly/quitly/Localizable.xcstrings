    "milestone_1yr_desc" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تعافى تلف الكبد بشكل كبير — انخفض خطر الإصابة بأمراض الكبد بشكل كبير"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Leberschäden haben sich deutlich erholt — Ihr Risiko für Lebererkrankungen ist drastisch gesunken"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Liver damage has significantly healed — your risk of liver disease has dropped dramatically"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El daño hepático se ha curado significativamente — el riesgo de enfermedad hepática ha caído drásticamente"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les dommages au foie ont considérablement guéri — le risque de maladie hépatique a chuté"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "肝臓のダメージが大幅に回復 — 肝臓疾患のリスクが劇的に低下しました"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "간 손상이 상당히 치유되었습니다 — 간 질환 위험이 극적으로 감소했습니다"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O dano hepático foi significativamente curado — o risco de doença hepática caiu drasticamente"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Повреждение печени значительно восстановлено — риск заболеваний печени резко снизился"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karaciğer hasarı önemli ölçüde iyileşti — karaciğer hastalığı riskiniz dramatik şekilde düştü"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "肝损伤已显著修复——肝病风险大幅下降"
          }
        }
      }
    },
