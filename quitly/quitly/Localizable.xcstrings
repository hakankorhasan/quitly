    "motivation_1" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنت أقوى من أي رغبة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du bist stärker als jedes Verlangen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You are stronger than any craving."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous êtes plus fort que n’importe quelle envie."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたはどんな欲求よりも強いのです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신은 어떤 갈망보다 강합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você é mais forte do que qualquer desejo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы сильнее любой жажды."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Herhangi bir arzudan daha güçlüsün."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你比任何渴望都更强大。"
          }
        }
      }
    },
    "motivation_2" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كل ساعة تقاوم فيها هي انتصار."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jede Stunde, in der Sie Widerstand leisten, ist ein Sieg."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Every hour you resist is a victory."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaque heure de résistance est une victoire."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あなたが抵抗するすべての時間は勝利です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신이 저항하는 모든 시간은 승리입니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada hora que você resiste é uma vitória."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Каждый час твоего сопротивления – это победа."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Direndiğin her saat bir zafer."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你的每一个小时的抵抗都是一次胜利。"
          }
        }
      }
    },
    "motivation_3" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نفسك المستقبلية فخورة بك الآن."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dein zukünftiges Ich ist jetzt stolz auf dich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your future self is proud of you right now."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre futur moi est fier de vous en ce moment."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "未来のあなたは今のあなたを誇りに思っています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "미래의 당신은 지금 당신을 자랑스럽게 생각합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Seu eu futuro está orgulhoso de você agora."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ваше будущее я сейчас гордится вами."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gelecekteki sen şu an seninle gurur duyuyor."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "未来的你现在为你感到骄傲。"
          }
        }
      }
    },
    "motivation_4" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذا الانزعاج مؤقت. حريتك دائمة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieses Unbehagen ist vorübergehend. Deine Freiheit ist dauerhaft."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This discomfort is temporary. Your freedom is permanent."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cet inconfort est temporaire. Votre liberté est permanente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この不快感は一時的なものです。あなたの自由は永遠です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이러한 불편함은 일시적입니다. 당신의 자유는 영구적입니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esse desconforto é temporário. Sua liberdade é permanente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Этот дискомфорт носит временный характер. Ваша свобода постоянна."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu rahatsızlık geçici. Özgürlüğün kalıcı."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这种不适是暂时的。你的自由是永久的。"
          }
        }
      }
    },
    "motivation_5" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أنت لم تأت إلى هذا الحد لتأتي إلى هذا الحد فقط."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du bist nicht so weit gekommen, um nur so weit zu kommen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You didn't come this far to only come this far."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous n'êtes pas venu jusqu'ici pour arriver jusqu'ici."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ここまで来るためにここまで来たわけではありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여기까지 오려고 여기까지 오신 게 아닙니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você não veio até aqui para chegar até aqui."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы зашли так далеко не для того, чтобы зайти так далеко."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Buralara kadar sadece buralara kadar gelmek için gelmedin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "你不是为了走到这一步才走到这一步的。"
          }
        }
      }
    },
    "motivation_6" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يوم واحد في كل مرة. لقد حصلت على هذا."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einen Tag nach dem anderen. Du hast das."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "One day at a time. You've got this."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un jour à la fois. Vous avez ça."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一日ずつ。これを持っていますね。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "한 번에 하루. 당신은 이것을 가지고 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um dia de cada vez. Você tem isso."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Один день за раз. У вас есть это."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Her seferinde bir gün. Bunu başarabilirsin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一次一天。你已经得到了这个。"
          }
        }
      }
    },
    "motivation_7" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سوف تمر الرغبة. قوتك لن تفعل ذلك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Verlangen wird vergehen. Deine Stärke wird es nicht tun."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The craving will pass. Your strength won't."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'envie passera. Votre force ne le fera pas."
