    },
    "mq_quote_15" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "فقط لأنك تشعر بذلك لا يعني أن عليك التصرف بناءً عليه."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nur weil Sie das Gefühl haben, dass es so ist, heißt das nicht, dass Sie entsprechend handeln müssen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You were given this life because you're strong enough to live it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Solo porque lo sientas no significa que debas actuar en consecuencia.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce n’est pas parce que vous le ressentez que vous devez agir en conséquence."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "そう感じたからといって、それに基づいて行動しなければならないわけではありません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "당신이 그것을 느낀다고 해서 당신이 그것에 따라 행동해야 한다는 것을 의미하지는 않습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Só porque você sente isso, não significa que você tenha que agir de acordo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "То, что вы это чувствуете, не означает, что вы должны действовать в соответствии с этим."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sırf hissediyorsun diye ona göre hareket etmek zorunda değilsin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅仅因为你感觉到了并不意味着你必须采取行动。"
          }
        }
      }
    },
    "mq_quote_16" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذا مجرد عقلك الذي يختبرك. لا تفشل في الاختبار."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das ist nur Ihr Verstand, der Sie auf die Probe stellt. Scheitern Sie den Test nicht."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fall seven times, stand up eight."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Esto es solo tu mente poniéndote a prueba. No repruebes la prueba.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "C'est juste votre esprit qui vous teste. N'échouez pas le test."
