    "mq_quote_150" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "امنحها القليل من الوقت. وسوف يتلاشى هذا الشعور."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geben Sie ihm etwas Zeit. Dieses Gefühl wird verblassen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Every sober decision is a deposit in your future happiness account."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"Dale un poco de tiempo. Este sentimiento se desvanecerá.\","
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Donnez-lui un peu de temps. Ce sentiment va s’estomper."
