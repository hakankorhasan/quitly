        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "反応する必要はありません。ただ観察してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "반응할 필요는 없습니다. 그냥 관찰하세요."
