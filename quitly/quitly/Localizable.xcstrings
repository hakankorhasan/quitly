          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Оставайся сильным еще немного. Вы почти у цели."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Biraz daha güçlü kal. Neredeyse başardın."
