        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "あと1時間だけ頑張ってください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "한 시간만 더 힘내세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fique forte por apenas mais uma hora."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Оставайтесь сильными еще один час."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
